const {
  name,
  class: className,
  size = '1em',
  'aria-label': ariaLabel,
} = Astro.props

const normalizedName = name.startsWith('lucide:') ? name.slice(7) : name
const paths = iconPaths[normalizedName] ?? iconPaths['file']
const dim = typeof size === 'number' ? `${size}px` : size
---

<svg
  class={className}
  width={dim}
  height={dim}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  role={ariaLabel ? 'img' : undefined}
  aria-label={ariaLabel}
  aria-hidden={ariaLabel ? undefined : 'true'}
  set:html={paths.join('')}
/>
