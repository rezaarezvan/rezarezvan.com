---
import { SITE } from '@/consts'
import { getLastRevision } from '@/lib/modified-time'
import { plainInlineMath } from '@/lib/math-utils'
import { getImage } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'

interface Props {
  post: CollectionEntry<
    'essays' | 'bachelor' | 'master' | 'exchange' | 'research'
  >
}

const { post } = Astro.props

const title = plainInlineMath(post.data.title || SITE.title)
const description =
  post.data.description ||
  (post.collection === 'essays'
    ? `An essay by Reza Rezvan: ${title}.`
    : SITE.description)
const defaultImage = new URL('/static/1200x630.png', Astro.site)
const image = post.data.image
  ? new URL(
      (
        await getImage({
          src: post.data.image,
          width: 1200,
          height: 630,
          format: 'webp',
          quality: 80,
        })
      ).src,
      Astro.site,
    )
  : defaultImage
const canonical = Astro.url
const published = post.data.date.toISOString()
const revised = getLastRevision(post.collection, post.id, post.data.date)
const doi =
  post.collection === 'research' && post.data.doiUrl
    ? post.data.doiUrl.replace(/^https?:\/\/(?:dx\.)?doi\.org\//, '')
    : null
---

<title>{`${title} | ${SITE.title}`}</title>
<meta name="title" content={`${title} | ${SITE.title}`}>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>

<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:image" content={image}>
<meta property="og:image:alt" content={title}>
<meta property="og:type" content="article">
<meta property="og:locale" content={SITE.locale}>
<meta property="og:site_name" content={SITE.title}>
<meta property="og:url" content={Astro.url}>
<meta property="article:published_time" content={published}>
{revised && (
  <meta property="article:modified_time" content={revised.toISOString()} />
)}

{post.collection === 'research' && (
  <>
    <meta name="citation_title" content={title} />
    {post.data.authors.map((author) => (
      <meta name="citation_author" content={author} />
    ))}
    <meta
      name="citation_publication_date"
      content={post.data.date.toISOString().slice(0, 10)}
    />
    {post.data.venue && (
      <meta name="citation_journal_title" content={post.data.venue} />
    )}
    {doi && <meta name="citation_doi" content={doi} />}
    {post.data.paperUrl && (
      <meta name="citation_abstract_html_url" content={post.data.paperUrl} />
    )}
  </>
)}

<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta property="twitter:image" content={image}>
<meta name="twitter:image:alt" content={title}>
<meta name="twitter:card" content="summary_large_image">
