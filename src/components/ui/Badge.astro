---
interface Props {
  variant?: 'default' | 'secondary' | 'destructive' | 'outline'
  href?: string
  class?: string
  className?: string
  [key: string]: unknown
}

const {
  variant = 'default',
  href,
  class: cls,
  className,
  ...rest
} = Astro.props
const Tag = href ? 'a' : 'span'
---

<Tag
  class:list={['badge', `badge-${variant}`, cls, className]}
  href={href}
  data-slot="badge"
  {...rest}
>
  <slot />
</Tag>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    gap: 0.25rem;
    white-space: nowrap;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .badge :global(svg) {
    width: 0.75rem;
    height: 0.75rem;
  }

  .badge-default {
    background-color: var(--primary);
    color: var(--primary-foreground);
  }

  .badge-secondary {
    background-color: var(--secondary);
    color: var(--secondary-foreground);
  }

  .badge-destructive {
    background-color: var(--destructive);
    color: var(--gray-1);
  }

  .badge-outline {
    color: var(--foreground);
    border-color: var(--border);
  }
</style>
