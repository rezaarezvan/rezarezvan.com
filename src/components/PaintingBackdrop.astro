---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  image: ImageMetadata
}

const { image } = Astro.props
---

<div class="painting-backdrop" aria-hidden="true">
  <Image
    src={image}
    alt=""
    widths={[1280, 1920]}
    sizes="100vw"
    format="webp"
    quality={72}
    loading="eager"
    decoding="async"
    class="painting-backdrop-img"
  />
  <div class="painting-backdrop-fade"></div>
</div>

<style>
  /* A full-bleed painting washed into the page: the image is fixed (gentle
     parallax) while the wrapper clips it — clip-path keeps clipping painted
     descendants without re-parenting the fixed child the way transform/filter
     would. */
  .painting-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: min(140vh, 1400px);
    z-index: -1;
    pointer-events: none;
    clip-path: inset(0);
  }

  .painting-backdrop-img {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100vh;
    object-fit: cover;
    opacity: 0.18;
    filter: saturate(0.85);
  }

  :global([data-theme="dark"]) .painting-backdrop-img {
    opacity: 0.11;
  }

  .painting-backdrop-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      color-mix(in oklab, var(--background) 15%, transparent) 0%,
      var(--background) 92%
    );
  }

  @media (prefers-reduced-motion: reduce) {
    .painting-backdrop-img {
      position: absolute;
      height: 100%;
    }
  }

  @media (max-width: 40rem) {
    .painting-backdrop {
      height: 100vh;
    }

    .painting-backdrop-img {
      opacity: 0.14;
    }
  }

  @media print {
    .painting-backdrop {
      display: none;
    }
  }
</style>
