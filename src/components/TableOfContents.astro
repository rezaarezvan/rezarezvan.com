---
import Icon from '@/components/Icon.astro'
import InlineMathText from '@/components/InlineMathText.astro'
import { getTocLabels } from '@/lib/toc-utils'
import { cn, getHeadingMargin } from '@/lib/utils'
import type { MarkdownHeading } from 'astro'

interface Props {
  headings: MarkdownHeading[]
  source?: string
}

const { headings, source = '' } = Astro.props
const labels = source
  ? getTocLabels(source, headings)
  : headings.map(({ text }) => text)
---

{headings.length > 0 && (
  <page-toc id="page-toc">
    <details class="toc-mobile">
      <summary class="toc-mobile-summary">
        <svg class="toc-progress" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="10" class="toc-progress-track" />
          <circle cx="12" cy="12" r="10" class="toc-progress-value" />
        </svg>
        <span class="toc-current" data-toc-current>Overview</span>
        <Icon name="chevron-down" class="toc-chevron size-4" />
      </summary>
      <nav class="toc-mobile-panel" aria-label="Table of contents">
        <ul class="toc-list">
          {headings.map((heading, index) => (
            <li class={cn('toc-item', getHeadingMargin(heading.depth))}>
              <a
                href={`#${heading.slug}`}
                class="toc-link"
                data-heading-id={heading.slug}
              >
                <InlineMathText text={labels[index]} />
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </details>

    <aside class="toc-desktop" aria-label="Table of contents">
      <span class="toc-title">Table of Contents</span>
      <nav class="toc-desktop-scroll">
        <ul class="toc-list">
          {headings.map((heading, index) => (
            <li class={cn('toc-item', getHeadingMargin(heading.depth))}>
              <a
                href={`#${heading.slug}`}
                class="toc-link"
                data-heading-id={heading.slug}
              >
                <InlineMathText text={labels[index]} />
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  </page-toc>
)}

<style>
  page-toc {
    display: block;
    width: 100%;
  }

  .toc-mobile-summary {
    display: flex;
    width: min(100%, var(--measure));
    margin-inline: auto;
    align-items: center;
    padding: var(--space-xs) var(--space-s);
    cursor: pointer;
    list-style: none;
  }

  .toc-mobile-summary::-webkit-details-marker {
    display: none;
  }

  .toc-progress {
    width: 1rem;
    height: 1rem;
    flex: none;
    margin-inline-end: var(--space-2xs);
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    transform: rotate(-90deg);
  }

  .toc-progress-track {
    color: color-mix(in oklab, var(--primary) 20%, transparent);
  }

  .toc-progress-value {
    color: var(--primary);
    stroke-dasharray: 62.832;
    stroke-dashoffset: 62.832;
  }

  .toc-current {
    min-width: 0;
    flex: 1;
    overflow: hidden;
    color: var(--muted-foreground);
    font-size: var(--step--1);
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .toc-chevron {
    flex: none;
    margin-inline-start: var(--space-2xs);
    color: var(--muted-foreground);
    transition: transform 0.2s ease;
  }

  details[open] .toc-chevron {
    transform: rotate(180deg);
  }

  .toc-mobile-panel {
    max-height: 30vh;
    overflow-y: auto;
    padding: 0 var(--space-s) var(--space-s);
  }

  .toc-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    list-style: none;
  }

  .toc-item {
    color: color-mix(in oklab, var(--foreground) 60%, transparent);
    font-size: var(--step--1);
  }

  .toc-link {
    text-decoration-color: transparent;
    text-underline-offset: 3px;
    transition:
      color 0.2s ease,
      text-decoration-color 0.2s ease;
  }

  .toc-link:hover {
    text-decoration-color: currentColor;
  }

  .toc-link[aria-current="location"] {
    color: var(--foreground);
  }

  .toc-desktop {
    display: none;
  }

  @media (min-width: 80rem) {
    page-toc {
      position: fixed;
      z-index: 40;
      top: 5rem;
      inset-inline-start: max(1rem, calc(50vw - 38rem));
      width: min(15rem, calc(50vw - var(--content-width) / 2 - 3rem));
      height: calc(100vh - 7rem);
    }

    .toc-mobile {
      display: none;
    }

    .toc-desktop {
      display: flex;
      max-height: 100%;
      flex-direction: column;
      gap: var(--space-2xs);
      padding-inline: var(--space-s);
    }

    .toc-title {
      flex: none;
      font-size: var(--step-1);
      font-weight: var(--font-weight-medium);
    }

    .toc-desktop-scroll {
      overflow-y: auto;
      padding-block-end: var(--space-s);
    }
  }
</style>

<script>
  const toc = document.getElementById('page-toc')

  if (toc) {
    const headings = Array.from(
      document.querySelectorAll<HTMLElement>(
        '.prose h2, .prose h3, .prose h4, .prose h5, .prose h6',
      ),
    )
    const links = Array.from(
      toc.querySelectorAll<HTMLAnchorElement>('[data-heading-id]'),
    )
    const current = toc.querySelector<HTMLElement>('[data-toc-current]')
    const progress = toc.querySelector<SVGCircleElement>('.toc-progress-value')
    const details = toc.querySelector<HTMLDetailsElement>('.toc-mobile')
    const desktopScroll = toc.querySelector<HTMLElement>('.toc-desktop-scroll')
    let frame = 0

    const copyHeadingContent = (target: HTMLElement, heading: HTMLElement) => {
      const copy = heading.cloneNode(true) as HTMLElement
      copy
        .querySelectorAll('[data-heading-anchor]')
        .forEach((anchor) => anchor.remove())
      target.replaceChildren(
        ...Array.from(copy.childNodes, (node) => node.cloneNode(true)),
      )
    }

    for (const link of links) {
      const heading = headings.find(({ id }) => id === link.dataset.headingId)
      if (heading) copyHeadingContent(link, heading)
    }

    const headerOffset = () =>
      (document.getElementById('site-header-shell')?.offsetHeight ?? 80) + 24

    const update = () => {
      frame = 0
      const marker = window.scrollY + headerOffset()
      let active: HTMLElement | undefined

      for (const heading of headings) {
        if (heading.offsetTop > marker) break
        active = heading
      }

      for (const link of links) {
        if (link.dataset.headingId === active?.id) {
          link.setAttribute('aria-current', 'location')
        } else {
          link.removeAttribute('aria-current')
        }
      }

      if (current) {
        if (active) copyHeadingContent(current, active)
        else current.textContent = 'Overview'
      }

      const distance = document.documentElement.scrollHeight - innerHeight
      const ratio =
        distance > 0 ? Math.min(1, Math.max(0, scrollY / distance)) : 0
      if (progress)
        progress.style.strokeDashoffset = String(62.832 * (1 - ratio))

      const desktopLink = links.find(
        (link) =>
          link.dataset.headingId === active?.id && link.closest('.toc-desktop'),
      )
      if (desktopLink && desktopScroll) {
        const area = desktopScroll.getBoundingClientRect()
        const item = desktopLink.getBoundingClientRect()
        if (item.top < area.top || item.bottom > area.bottom) {
          desktopLink.scrollIntoView({ block: 'nearest' })
        }
      }
    }

    const scheduleUpdate = () => {
      if (!frame) frame = requestAnimationFrame(update)
    }

    for (const link of links) {
      link.addEventListener('click', () => {
        if (details) details.open = false
      })
    }

    addEventListener('scroll', scheduleUpdate, { passive: true })
    addEventListener('resize', scheduleUpdate, { passive: true })
    update()
  }
</script>
