---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import EssayListItem from '@/components/EssayListItem.astro'
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllEssays, groupEssaysByYear } from '@/lib/essay-utils'
import { hasInlineMath } from '@/lib/math-utils'

const essays = await getAllEssays()
const essaysByYear = groupEssaysByYear(essays)
const years = Object.keys(essaysByYear).sort((a, b) => Number(b) - Number(a))
---

<Layout
  class="listing-shell"
  math={essays.some((essay) => hasInlineMath(essay.data.title))}
>
  <PageHead
    slot="head"
    title="Essays"
    description="Essays by Reza Rezvan on research, technical ideas, tools, and life."
  />
  <Breadcrumbs
    items={[{ label: 'Essays', href: '/essays/', icon: 'lucide:library-big' }]}
  />

  <header class="listing-head">
    <h1>Essays</h1>
    <p>
      A collection of my technical writing and the occasional wandering
      thoughts.
    </p>
  </header>

  <div class="listing-years" data-pagefind-ignore>
    {years.map((year) => (
      <section class="listing-year-group">
        <h2 class="listing-year">{year}</h2>
        <ol class="essay-list">
          {essaysByYear[year].map((essay) => (
            <li><EssayListItem essay={essay} /></li>
          ))}
        </ol>
      </section>
    ))}
  </div>
</Layout>

<style>
  .listing-head {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }

  .listing-head h1,
  .listing-head p,
  .listing-year {
    margin: 0;
  }

  .listing-head h1 {
    font-size: var(--step-3);
    font-weight: var(--font-weight-normal);
  }

  .listing-head p {
    color: var(--prose-foreground);
    font-size: var(--step-0);
  }

  .listing-years,
  .listing-year-group {
    display: flex;
    flex-direction: column;
  }

  .listing-years {
    min-height: calc(100vh - 18rem);
    gap: var(--space-l);
  }

  .listing-year-group {
    gap: var(--space-2xs);
  }

  .listing-year {
    color: var(--muted-foreground);
    font-size: var(--step-0);
    font-weight: var(--font-weight-medium);
    font-variant-numeric: lining-nums tabular-nums;
  }

  .essay-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .essay-list li:last-child :global(.essay-list-item) {
    border-block-end: 1px solid var(--border);
  }
</style>
