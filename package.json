{
  "name": "rezvan-site",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev",
    "build": "node build.mjs",
    "deploy": "gh workflow run deploy.yml --repo rezaarezvan/rezarezvan.com --ref main",
    "preview": "astro preview",
    "astro": "astro",
    "check": "npm run format:check && npm run test:equations && node build.mjs --check",
    "check:equations": "node scripts/check-equation-references.mjs",
    "test:equations": "node --test scripts/check-equation-references.test.mjs",
    "check:rendered": "node scripts/check-rendered-markdown.mjs dist",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "dependencies": {
    "@astrojs/markdown-satteri": "^0.3.4",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@expressive-code/plugin-collapsible-sections": "^0.44.0",
    "@expressive-code/plugin-line-numbers": "^0.44.0",
    "astro": "^7.1.1",
    "entities": "^4.5.0",
    "github-slugger": "^2.0.0",
    "hast-util-select": "^6.0.4",
    "hast-util-to-html": "^9.0.5",
    "hastscript": "^9.0.1",
    "katex": "^0.18.1",
    "satteri": "^0.9.5",
    "satteri-expressive-code": "^0.1.18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "pagefind": "^1.5.2"
  }
}
